# PluggedIN Environment Variables
# Copy this to .env and fill in your keys
# NEVER commit .env to GitHub
# NEVER share these keys in chat

# Render (production server URL)
RENDER_URL=https://your-app.onrender.com

# Anthropic
ANTHROPIC_API_KEY=

# OpenRouter (free models backup)
OPENROUTER_API_KEY=

# Apify (web scraping)
APIFY_TOKEN=

# TinyFish (intelligent browsing)
TINYFISH_API_KEY=

# Airtable (CRM)
AIRTABLE_TOKEN=
AIRTABLE_BASE_PLUGGEDIN=
AIRTABLE_BASE_GROMATIC=

# Vibe Prospecting (B2B contacts)
VIBE_PROSPECTING_KEY=

# Relevance AI (agent platform)
RELEVANCE_AI_KEY=
RELEVANCE_PROJECT_ID=

# Creatomate (video and image ad generation)
CREATOMATE_API_KEY=

# Cal.com (meeting booking)
CALCOM_API_KEY=

# VAPI (voice agents)
VAPI_API_KEY=

# GitHub (skill discovery - 5,000 req/hr with token vs 60 without)
GITHUB_TOKEN=

# Reddit (Market Scout — free, just needs a free Reddit app)
# Setup: https://www.reddit.com/prefs/apps → Create App → script
# Without these: uses RSS feeds (still works, just fewer results)
# With these: 60 req/min, full search, subreddit browsing
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Airtable bases (add more as you onboard clients)
AIRTABLE_BASE_AGENCY=

# Smartlead (future - when budget allows)
# SMARTLEAD_API_KEY=
